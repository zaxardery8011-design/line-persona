# LINE Messaging API channel access token
LINE_CHANNEL_ACCESS_TOKEN=

# LINE Messaging API channel secret
LINE_CHANNEL_SECRET=

# Local server port
PORT=3000

# OpenAI-compatible chat completions endpoint base URL
LLM_BASE_URL=

# API key for your LLM provider. Local Ollama can leave this empty.
LLM_API_KEY=

# Model name used by your provider
LLM_MODEL=

# Cloud example: OpenAI-compatible provider
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-api-key
# LLM_MODEL=gpt-4.1-mini

# Cloud example: Gemini or Claude through an OpenAI-compatible gateway
# LLM_BASE_URL=https://your-gateway.example.com/v1
# LLM_API_KEY=your-gateway-api-key
# LLM_MODEL=gemini-2.5-flash

# Local example: Ollama OpenAI-compatible endpoint
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=
# LLM_MODEL=llama3.1

